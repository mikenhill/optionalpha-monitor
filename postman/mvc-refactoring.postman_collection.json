    {
      "name": "Dates API",
      "item": [
        {
          "name": "Get All Dates (MVC)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5050/mvc/api/dates?test_mode=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["mvc", "api", "dates"],
              "query": [
                {
                  "key": "test_mode",
                  "value": "1",
                  "description": "Enable test mode to see metadata"
                }
              ]
            },
            "description": "Get all available dates with test mode enabled (MVC version)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success field\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success');",
                  "});",
                  "",
                  "pm.test(\"Response has data field\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Data is an array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Test metadata present\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('test_metadata');",
                  "    pm.expect(jsonData.test_metadata).to.have.property('test_mode', true);",
                  "    pm.expect(jsonData.test_metadata).to.have.property('dao_used');",
                  "    pm.expect(jsonData.test_metadata).to.have.property('timestamp');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
