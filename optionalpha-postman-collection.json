{
  "info": {
    "name": "Option Alpha API Capture",
    "description": "Replay captured Option Alpha RPC calls. Requires valid session cookies copied from a fresh browser session. Do not commit filled cookie values.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://app.optionalpha.com" },
    { "key": "local_url", "value": "http://localhost:5050" },
    { "key": "symbol", "value": "SPX" },
    { "key": "xid", "value": "SPX_20260602" },
    { "key": "a5sid", "value": "PASTE_A5SID_HERE" },
    { "key": "a5did", "value": "PASTE_A5DID_HERE" },
    { "key": "cf_clearance", "value": "PASTE_CF_CLEARANCE_HERE" }
  ],
  "item": [
    {
      "name": "Batched - Max Pain + GEX",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json, text/plain, */*" },
          { "key": "Origin", "value": "https://app.optionalpha.com" },
          { "key": "Referer", "value": "https://app.optionalpha.com/screener?symbols=SPX%2CXSP" },
          { "key": "Cookie", "value": "a5sid={{a5sid}}; a5did={{a5did}}; cf_clearance={{cf_clearance}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/request",
          "host": ["{{base_url}}"],
          "path": ["api", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"t\": \"rpc\",\n    \"tid\": \"postman-maxpain-{{$timestamp}}\",\n    \"api\": \"market.maxpain\",\n    \"args\": [\n      {\n        \"symbol\": \"{{symbol}}\",\n        \"xid\": \"{{xid}}\"\n      }\n    ]\n  },\n  {\n    \"t\": \"rpc\",\n    \"tid\": \"postman-gex-{{$timestamp}}\",\n    \"api\": \"market.gex\",\n    \"args\": [\n      \"{{symbol}}\",\n      \"{{xid}}\"\n    ]\n  }\n]"
        },
        "description": "Confirmed captured batch from the screener page. market.maxpain response bars include volume/open-interest style fields: cvol, pvol, coi, poi. market.gex response includes gamma exposure data."
      }
    },
    {
      "name": "Market Max Pain",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json, text/plain, */*" },
          { "key": "Origin", "value": "https://app.optionalpha.com" },
          { "key": "Referer", "value": "https://app.optionalpha.com/screener?symbols=SPX%2CXSP" },
          { "key": "Cookie", "value": "a5sid={{a5sid}}; a5did={{a5did}}; cf_clearance={{cf_clearance}}" }
        ],
        "url": "{{base_url}}/api/request",
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"t\": \"rpc\",\n    \"tid\": \"postman-maxpain-{{$timestamp}}\",\n    \"api\": \"market.maxpain\",\n    \"args\": [\n      {\n        \"symbol\": \"{{symbol}}\",\n        \"xid\": \"{{xid}}\"\n      }\n    ]\n  }\n]"
        },
        "description": "Returns max-pain data. The `bars` array includes fields including strike, calls, puts, total, cvol, pvol, coi, poi."
      }
    },
    {
      "name": "Market GEX",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json, text/plain, */*" },
          { "key": "Origin", "value": "https://app.optionalpha.com" },
          { "key": "Referer", "value": "https://app.optionalpha.com/screener?symbols=SPX%2CXSP" },
          { "key": "Cookie", "value": "a5sid={{a5sid}}; a5did={{a5did}}; cf_clearance={{cf_clearance}}" }
        ],
        "url": "{{base_url}}/api/request",
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"t\": \"rpc\",\n    \"tid\": \"postman-gex-{{$timestamp}}\",\n    \"api\": \"market.gex\",\n    \"args\": [\n      \"{{symbol}}\",\n      \"{{xid}}\"\n    ]\n  }\n]"
        },
        "description": "Returns gamma exposure data. Confirmed captured call from screener page."
      }
    },
    {
      "name": "Local APIs",
      "item": [
        {
          "name": "Upsert Historical Snapshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{local_url}}/mvc/api/snapshot/historical",
              "host": ["{{local_url}}"],
              "path": ["mvc", "api", "snapshot", "historical"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"SPX\",\n  \"ndate\": 20260625,\n  \"ntime\": 1400,\n  \"uprice\": 7358.22,\n  \"data\": []\n}"
            },
            "description": "Upsert a historical snapshot from OptionAlpha market.histgex API. Add ?test=1 to set source='test' for testing."
          }
        },
        {
          "name": "Upsert Live Snapshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{local_url}}/mvc/api/snapshot/live",
              "host": ["{{local_url}}"],
              "path": ["mvc", "api", "snapshot", "live"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"SPX\",\n  \"last\": 7354.02,\n  \"low\": {},\n  \"high\": {},\n  \"data\": []\n}"
            },
            "description": "Upsert a live snapshot from OptionAlpha market.gex API. Normalizes to historical format with current timestamp. Add ?test=1 to set source='test' for testing."
          }
        },
        {
          "name": "Delete Snapshot",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{local_url}}/mvc/api/snapshot?date=2026-06-25&time=1400&symbol=SPX",
              "host": ["{{local_url}}"],
              "path": ["mvc", "api", "snapshot"],
              "query": [
                { "key": "date", "value": "2026-06-25" },
                { "key": "time", "value": "1400" },
                { "key": "symbol", "value": "SPX" }
              ]
            },
            "description": "Delete a snapshot from the database by date, time, and optional symbol (default SPX)."
          }
        },
        {
          "name": "Upsert GEX Strike Window (Historical Format)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{local_url}}/mvc/api/gex/upsert?source=gex&test=0",
              "host": ["{{local_url}}"],
              "path": ["mvc", "api", "gex"],
              "query": [
                { "key": "source", "value": "gex", "description": "Optional: default gex" },
                { "key": "test", "value": "0", "description": "Optional: set to 1 to force source='test'" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"t\": \"res\",\n    \"tid\": \"test-tid\",\n    \"api\": \"market.histgex\",\n    \"data\": {\n      \"symbol\": \"SPX\",\n      \"ndate\": 20260623,\n      \"ntime\": 1000,\n      \"uprice\": 7399.45,\n      \"data\": []\n    }\n  }\n]"
            },
            "description": "Upsert GEX strike window data using historical format (from OptionAlpha market.histgex API). Extracts 40-strike window and stores in gex_strike_window table."
          }
        },
        {
          "name": "Upsert GEX Strike Window (Live Format)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{local_url}}/mvc/api/gex/upsert?date=2026-06-28&time=1526&source=gex&test=0",
              "host": ["{{local_url}}"],
              "path": ["mvc", "api", "gex"],
              "query": [
                { "key": "date", "value": "2026-06-28", "description": "Required for live format: YYYY-MM-DD" },
                { "key": "time", "value": "1526", "description": "Required for live format: HHMM" },
                { "key": "source", "value": "gex", "description": "Optional: default gex" },
                { "key": "test", "value": "0", "description": "Optional: set to 1 to force source='test'" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"t\": \"res\",\n    \"tid\": \"test-tid\",\n    \"api\": \"market.gex\",\n    \"data\": {\n      \"symbol\": \"SPX\",\n      \"last\": 7354.02,\n      \"low\": {},\n      \"high\": {},\n      \"data\": []\n    }\n  }\n]"
            },
            "description": "Upsert GEX strike window data using live format (from OptionAlpha market.gex API). Requires date and time query params. Extracts 40-strike window and stores in gex_strike_window table."
          }
        }
      ]
    },
    {
      "name": "GEX Admin",
      "item": [
        {
          "name": "Verify Strike Window Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{local_url}}/api/gex/verify-strike-window",
              "host": ["{{local_url}}"],
              "path": ["api", "gex", "verify-strike-window"]
            },
            "description": "Verify that all historical dates in gex_strike_window have mandatory RTH time slots (935-1555). Returns summary and detailed results per date."
          }
        },
        {
          "name": "Verify Percentile Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{local_url}}/api/gex/verify-percentiles",
              "host": ["{{local_url}}"],
              "path": ["api", "gex", "verify-percentiles"]
            },
            "description": "Verify that all historical snapshots have percentile data for all metrics. Returns summary and detailed results per snapshot."
          }
        }
      ]
    }
  ]
}
